# Database
DATABASE_URL=sqlite:///./dev.db

# Redis (optional — omit for in-memory cache fallback)
REDIS_URL=

# API
API_PREFIX=/api/v1
SECRET_KEY=change-me-in-production

# Crawler
CRAWLER_RETRY_TIMES=3
CRAWLER_RETRY_BASE_DELAY=1.0
CRAWLER_POLITE_DELAY=0.5

# News sources (comma-separated URLs or source names)
NEWS_RSS_URLS=https://finance.eastmoney.com/rss,https://www.cls.cn/rss

# Sentiment (optional)
SENTIMENT_ENABLED=false
